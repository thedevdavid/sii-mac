{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window. All filesystem IO goes through Rust commands (which aren't scope-bound), so the frontend needs no fs: permissions at all.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:allow-reveal-item-in-dir",
    "opener:allow-open-url",
    "opener:allow-open-path",
    "dialog:allow-open",
    "dialog:allow-save",
    "os:allow-platform",
    "process:allow-restart",
    "store:default",
    "updater:default"
  ]
}
